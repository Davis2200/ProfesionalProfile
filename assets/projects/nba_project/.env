# --- CONFIGURACIÓN DE BASE DE DATOS (PostgreSQL 14) ---
# Si corres la DB en tu misma PC, usa localhost o 127.0.0.1
DB_USER=DavisNA
DB_PORT=5432
DB_NAME=nba_stats
DB_USER=postgres
DB_PASSWORD=postgres

# --- CONFIGURACIÓN DE LOCALIZACIÓN (CDMX) ---
# Esto es vital para que tus scripts de 'recoleccion' no guarden horas erróneas
TIMEZONE=America/Mexico_City
APP_REGION=MX

# --- RUTAS ESTRUCTURALES DEL PROYECTO ---
# Rutas donde los scripts distribuidos guardarán los modelos entrenados (.pkl)
MODELS_DIR=./models/inference/bin
LOGS_DIR=./data_pipeline/recoleccion/logs

# --- PARÁMETROS DE LA API (FastAPI) ---
# Definimos dónde escuchará tu API para que Streamlit sepa a dónde apuntar
API_URL=http://127.0.0.1:8000
DEBUG_MODE=True

# --- OBJETIVOS DE PRECISIÓN DEL MODELO ---
# Definidos según tus restricciones de MAE y MSE
MIN_MAE_THRESHOLD=0.01
MIN_MSE_THRESHOLD=0.001